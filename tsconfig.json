{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,

    "target": "es2022",
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "ESNext",
    "types": ["node"],
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "declaration": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts"]
}
