    "biome": "^0.3.3",
    "lefthook": "^2.1.5",
    "tsc": "^2.0.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "@hono/node-server": "^1.19.14"
  },
  "dependencies": {
    "hono": "^4.12.12",
    "reflect-metadata": "^0.2.2"
